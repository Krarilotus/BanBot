# Discord bot token from the Discord Developer Portal.
DISCORD_TOKEN=

# Discord application client ID, used to register /banbot and print invite URLs.
CLIENT_ID=

# Default mode for newly configured Discord servers.
ACTION_MODE=dry-run

# Default delete window for newly configured Discord servers.
# Max: 604800 = 7 days.
DELETE_MESSAGE_SECONDS=86400

# Persistent JSON config written by /banbot setup.
CONFIG_PATH=/data/config.json

# Optional. Bind address for health endpoint.
HEALTH_HOST=127.0.0.1

# Optional. Health endpoint port. Leave empty to disable.
HEALTH_PORT=
