# Discord bot token from the Discord Developer Portal.
DISCORD_TOKEN=

# Discord application client ID, used to register /banbot and print invite URLs.
CLIENT_ID=

# Comma-separated Discord channel IDs that act as trap channels.
TRAP_CHANNEL_IDS=

# Optional Discord channel ID where the bot logs actions.
LOG_CHANNEL_ID=

# dry-run = log only. ban = actually ban matching users.
ACTION_MODE=dry-run

# Required safety confirmation for ban mode.
# Ban mode only works when ACTION_MODE=ban and CONFIRM_CONFIG=true.
CONFIRM_CONFIG=false

# How many seconds of the banned user's recent messages Discord should delete.
# Max: 604800 = 7 days.
DELETE_MESSAGE_SECONDS=86400

# Optional. Bind address for health endpoint.
HEALTH_HOST=127.0.0.1

# Optional. Health endpoint port. Leave empty to disable.
HEALTH_PORT=
